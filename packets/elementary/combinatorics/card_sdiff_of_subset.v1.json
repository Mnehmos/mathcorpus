  "informal_statement": "If t is a subset of s, the number of elements in s but not in t equals the size of s minus the size of t.",
  "informal_proof_idea": "Directly `Finset.card_sdiff_of_subset`.",
  "formal_statement_pp": "theorem card_sdiff_of_subset' (s t : Finset ℕ) (h : t ⊆ s) : (s \\ t).card = s.card - t.card",
