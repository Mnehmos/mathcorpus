  "informal_statement": "For integers a, b, c, if a divides b and a divides c then a divides b + c.",
  "informal_proof_idea": "Divisibility is closed under addition: `dvd_add` applied to the two hypotheses.",
  "formal_statement_pp": "theorem dvd_add_of_dvd (a b c : ℤ) (hb : a ∣ b) (hc : a ∣ c) : a ∣ (b + c)",
