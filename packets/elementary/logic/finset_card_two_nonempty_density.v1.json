  "informal_statement": "For any non-empty family F of finsets of size at most 2 containing at least one non-empty set, there exists an element x belonging to at least half of the sets in F.",
  "informal_proof_idea": "Extract x from the non-empty set s in F. Then s is in F.filter (x ∈ ·), giving filter size >= 1, so 2 * 1 = 2 >= F.card.",
  "formal_statement_pp": "theorem finset_card_two_nonempty_density' : ∀ {α : Type*} [DecidableEq α] (F : Finset (Finset α)), F.Nonempty → F.card ≤ 2 → (∃ s ∈ F, s.Nonempty) → ∃ x, 2 * (F.filter (fun s => x ∈ s)).card ≥ F.card",
