  "informal_statement": "For any non-empty finset A and finset B, the union A ∪ B contains an element.",
  "informal_proof_idea": "Extract x from A, then x is in A ∪ B via Finset.mem_union_left.",
  "formal_statement_pp": "theorem union_pair_element : ∀ {α : Type*} [DecidableEq α] (A B : Finset α), A.Nonempty → ∃ x, x ∈ A ∪ B",
