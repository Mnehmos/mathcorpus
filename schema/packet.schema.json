{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Mnehmos/mathcorpus/schema/packet.schema.json",
  "title": "MathCorpus Concept Packet",
  "description": "The unit of curation, review, hashing, and export in MathCorpus. Cross-field policy rules (encoding-soundness, provenance completeness, certificate/CNF binding, template-locked splits) are enforced by tools/validate_packets.py in addition to this structural schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_version",
    "title",
    "domain",
    "level",
    "kind",
    "status",
    "source_provenance",
    "proof_body_redacted",
    "trust",
    "training",
    "hashes"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Lowercase hex SHA-256 digest."
    },
    "sha256_or_null": {
      "oneOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "proof_class": {
      "type": "string",
      "enum": [
        "theorem_lookup", "normalization", "arithmetic_automation", "induction",
        "witness_construction", "case_analysis", "multi_lemma_composition"
      ]
    },
    "proof_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_proof_class"],
      "properties": {
        "primary_proof_class": { "$ref": "#/$defs/proof_class" },
        "secondary_proof_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/proof_class" },
          "uniqueItems": true
        },
        "automation_level": { "type": "string", "enum": ["none", "assisted", "semi_automated", "fully_automated"] },
        "retrieval_depth": { "type": "integer", "minimum": 0 },
        "planning_depth": { "type": "integer", "minimum": 0 },
        "branch_count": { "type": "integer", "minimum": 0 },
        "dependency_composition_depth": { "type": "integer", "minimum": 0 },
        "uses_witness_invention": { "type": "boolean" },
        "uses_induction": { "type": "boolean" },
        "uses_contradiction": { "type": "boolean" },
        "uses_case_analysis": { "type": "boolean" }
      }
    },
    "dependency_claim_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency_id", "category", "source"],
      "properties": {
        "dependency_id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "declared", "used", "obligation", "verified_module_item",
            "retrieval_candidate", "retrieved_unused"
          ]
        },
        "source": { "type": "string", "enum": ["manual", "proof_search_import", "verifier_export"] }
      }
    },
    "dependency_manifest": {
      "type": "object",
      "additionalProperties": false,
      "description": "Richer, Proof-Search-sourced dependency evidence. Distinct from (and additive to) the shallow top-level 'dependencies' object: this record distinguishes declared, retrieved, and actually-used dependencies rather than merging them into one list.",
      "properties": {
        "environment_hash": { "type": "string" },
        "declared_theorem_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "used_theorem_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "obligation_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "verified_module_item_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "transitive_dependency_count": { "type": ["integer", "null"], "minimum": 0 },
        "transitive_dependency_depth": { "type": ["integer", "null"], "minimum": 0 },
        "retrieval_candidates": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "retrieved_unused_candidates": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "claim_sources": { "type": "array", "items": { "$ref": "#/$defs/dependency_claim_source" } }
      }
    },
    "proof_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id", "variant_style", "proof_body_redacted", "source"],
      "properties": {
        "variant_id": { "type": "string", "minLength": 1 },
        "variant_style": {
          "type": "string",
          "enum": ["canonical", "shortest", "pedagogical", "restricted", "interactive", "alternate_model"]
        },
        "formal_statement_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "environment_hash": { "type": "string" },
        "proof_body_path": { "type": "string" },
        "proof_body_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_body_redacted": { "type": "boolean" },
        "tactic_count": { "type": ["integer", "null"], "minimum": 0 },
        "proof_length": { "type": ["integer", "null"], "minimum": 0 },
        "restriction_profile_id": { "type": ["string", "null"] },
        "restriction_profile_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_profile": { "$ref": "#/$defs/proof_profile" },
        "source": { "type": "string", "enum": ["human_authored", "proof_search", "imported"] }
      },
      "allOf": [
        {
          "if": { "properties": { "variant_style": { "const": "restricted" } } },
          "then": { "required": ["restriction_profile_id", "restriction_profile_sha256"] }
        }
      ]
    }
  },
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._][a-z0-9]+)*\\.v[0-9]+$",
      "description": "Stable corpus identifier, e.g. elementary.algebra.diff_of_squares.v1"
    },
    "packet_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version for packet metadata and artifacts."
    },
    "title": { "type": "string", "minLength": 1 },
    "domain": {
      "type": "string",
      "enum": [
        "arithmetic", "algebra", "number_theory", "combinatorics",
        "analysis", "real_analysis", "geometry", "topology", "logic",
        "linear_algebra", "abstract_algebra", "set_theory", "probability",
        "frontier"
      ]
    },
    "level": {
      "type": "string",
      "enum": [
        "L0_elementary", "L1_proof_basics", "L2_olympiad", "L3_undergrad",
        "L4_advanced_undergrad", "L5_grad", "L6_known_theorem", "L7_frontier"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "concept", "theorem", "exercise", "certificate_claim",
        "negative_example", "benchmark_item", "frontier_artifact"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "kernel_verified", "verified_certificate", "formula_fact_only",
        "empirical_only", "failed_attempt", "redacted_public_metadata_only"
      ]
    },
    "difficulty_bin": {
      "type": "string",
      "enum": ["D0", "D1", "D2", "D3", "D4", "D5"],
      "description": "Packet-native difficulty bin used by the evaluation suite."
    },
    "lean_module": { "type": "string", "description": "Lean module path (required for formal items)." },
    "theorem_name": { "type": "string", "description": "Lean theorem/def name (required for formal items)." },
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit import list (required for formal items)."
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lean_version": { "type": "string" },
        "mathlib_rev": { "type": "string" },
        "std_rev": { "type": "string" },
        "lake_manifest_sha256": { "$ref": "#/$defs/sha256_or_null" }
      },
      "required": ["lean_version", "mathlib_rev"]
    },
    "source_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "authors", "statement_fidelity"],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "author_written", "adapted_public_source", "formal_conjectures",
            "erdos_problems", "proofnet_style", "repo_original",
            "imported_open_repo", "benchmark_statement", "private_audit"
          ]
        },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "authors": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "copyright_holder": { "type": "string" },
        "license_spdx": { "type": "string", "description": "SPDX id for code-like assets, e.g. Apache-2.0" },
        "license_content": { "type": "string", "description": "License for prose-like assets, e.g. CC-BY-4.0" },
        "statement_fidelity": {
          "type": "string",
          "enum": [
            "author_written", "canonical_statement_hash_match",
            "problem_fidelity_verified", "adapted_with_review", "unknown"
          ]
        },
        "provenance_attested_by": { "type": "string" },
        "provenance_checked_at": { "type": "string" }
      }
    },
    "informal_statement": { "type": "string" },
    "informal_proof_idea": { "type": "string" },
    "formal_statement_pp": { "type": "string", "description": "Pretty-printed formal statement, toolchain-pinned (required for formal items)." },
    "proof_body_path": { "type": "string", "description": "Path to Lean proof file, if public." },
    "proof_body_redacted": { "type": "boolean" },
    "certificate": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "certificate_type": { "type": "string", "enum": ["lrat", "drat", "sat_model", "cnf_witness", "none"] },
        "certificate_checker": { "type": "string", "enum": ["bv_decide_lrat", "lrat_import", "model_eval", "none"] },
        "certificate_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "certificate_artifact_redacted": { "type": "boolean" },
        "canonical_cnf_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "dimacs_serializer_version": { "type": "string" },
        "solver_name": { "type": "string" },
        "solver_version": { "type": "string" },
        "checked_at": { "type": "string" },
        "checked_by_module": { "type": "string" },
        "replay_runtime_ms": { "type": "number", "minimum": 0 },
        "memory_class": { "type": "string", "enum": ["small", "medium", "large"] },
        "private_artifact_uri": { "type": "string" }
      }
    },
    "encoding_soundness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "encoding_required": { "type": "boolean" },
        "encoding_soundness_status": { "type": "string", "enum": ["not_applicable", "stated_directly", "proved", "missing"] },
        "encoding_soundness_lemma": { "type": ["string", "null"] },
        "formula_fact_status": { "type": "string", "enum": ["proved", "not_applicable", "failed"] },
        "math_fact_status": { "type": "string", "enum": ["proved", "formula_fact_only", "empirical_only"] }
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rung", "proof_authority"],
      "properties": {
        "rung": { "type": "integer", "minimum": 0, "maximum": 5 },
        "proof_authority": { "type": "string", "enum": ["lean_kernel", "lean_verified_lrat", "kernel_rechecked_witness", "none"] },
        "certificate_checker": { "type": "string", "enum": ["kernel_decide", "bv_decide_lrat", "model_eval", "lrat_import", "none"] },
        "formula_fact_status": { "type": "string", "enum": ["proved", "not_applicable", "failed"] },
        "math_fact_status": { "type": "string", "enum": ["proved", "formula_fact_only", "empirical_only"] },
        "encoding_required": { "type": "boolean" },
        "encoding_soundness_status": { "type": "string", "enum": ["not_applicable", "stated_directly", "proved", "missing"] },
        "independent_review_status": { "type": "string", "enum": ["none", "self_reviewed", "repo_reviewed", "external_reviewed"] },
        "public_claim_class": { "type": "string", "enum": ["public_safe", "restricted", "private_only"] }
      }
    },
    "training": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligibility"],
      "properties": {
        "eligibility": {
          "type": "string",
          "enum": [
            "public_train", "public_val", "public_test", "heldout_public",
            "heldout_private", "quarantined", "quarantined_benchmark",
            "negative_example_only", "private_audit_only", "disallowed"
          ]
        },
        "split": { "type": "string", "enum": ["train", "val", "test_public", "heldout_public", "heldout_private", "quarantined", "private_audit_only"] },
        "reason_codes": { "type": "array", "items": { "type": "string" } },
        "dedupe_cluster_id": { "type": "string" },
        "template_family_id": { "type": "string" },
        "benchmark_tags": { "type": "array", "items": { "type": "string" } },
        "open_problem_related": { "type": "boolean" },
        "contamination_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "can_export_proof_body": { "type": "boolean" },
        "can_export_certificate_metadata": { "type": "boolean" },
        "can_export_certificate_file": { "type": "boolean" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured record for negative_example / failed_attempt packets.",
      "properties": {
        "gap_category": { "type": "string" },
        "sub_category": { "type": "string" },
        "input_context_summary": { "type": "string" },
        "attempt_summary": { "type": "string" },
        "lesson": { "type": "string" }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theorem_deps": { "type": "array", "items": { "type": "string" } },
        "kits": { "type": "array", "items": { "type": "string" } },
        "tactic_tags": { "type": "array", "items": { "type": "string" } },
        "prerequisite_concepts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "proof_variants": {
      "type": "array",
      "description": "Zero or more additional proofs of this packet's statement, in styles other than (or including) the canonical proof_body_path. Adding variants never mutates the packet's own canonical identity/hash fields. See schema/mcip/v1/README.md — these mirror the MCIP ProofVariant/ProofProfile shapes. Cross-field checks (statement/environment/proof hash must match parent evidence; restricted variants must hash-pin a resolvable restriction profile) are enforced by tools/validate_packets.py.",
      "items": { "$ref": "#/$defs/proof_variant" }
    },
    "dependency_manifest": { "$ref": "#/$defs/dependency_manifest" },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "loc": { "type": "integer", "minimum": 0 },
        "tactic_count": { "type": "integer", "minimum": 0 },
        "runtime_ms": { "type": "number", "minimum": 0 },
        "heartbeats": { "type": "integer", "minimum": 0 },
        "proof_length": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "public_files": { "type": "array", "items": { "type": "string" } },
        "private_artifact_inventory": { "type": "array", "items": { "type": "string" } }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_basis": { "type": "string" },
        "reviewer_status": { "type": "string", "enum": ["none", "self_reviewed", "repo_reviewed", "external_reviewed"] },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "description": "Provenance of the tracked verifier run that produced this packet's proof authority. Present on kernel_verified / verified_certificate packets produced through the proof-search loop.",
      "properties": {
        "verifier": { "type": "string", "description": "e.g. 'proofsearch'" },
        "environment_hash": { "type": "string", "description": "Pinned Lean+mathlib environment hash the kernel ran under." },
        "episode_id": { "type": "string" },
        "outcome": { "type": "string", "enum": ["kernel_verified", "certified", "verified_certificate"] },
        "kernel_verified": { "type": "boolean" },
        "fidelity_status": { "type": "string", "enum": ["attested", "verified", "unreviewed"] },
        "import_manifest_hash": { "type": "string" },
        "trajectory_first_hash": { "type": "string" },
        "trajectory_last_hash": { "type": "string" },
        "step_count": { "type": "integer", "minimum": 0 },
        "verified_at": { "type": "string" }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_sha256"],
      "properties": {
        "source_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "formal_statement_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_body_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "module_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "canonical_cnf_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "certificate_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "private_artifact_bundle_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "packet_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "notes": { "type": "string" }
  }
}
