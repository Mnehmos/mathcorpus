{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Mnehmos/mathcorpus/schema/packet.schema.json",
  "title": "MathCorpus Concept Packet",
  "description": "The unit of curation, review, hashing, and export in MathCorpus. Cross-field policy rules (encoding-soundness, provenance completeness, certificate/CNF binding, template-locked splits) are enforced by tools/validate_packets.py in addition to this structural schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "packet_version",
    "title",
    "domain",
    "level",
    "kind",
    "status",
    "source_provenance",
    "proof_body_redacted",
    "trust",
    "training",
    "hashes"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Lowercase hex SHA-256 digest."
    },
    "sha256_or_null": {
      "oneOf": [
        { "$ref": "#/$defs/sha256" },
        { "type": "null" }
      ]
    },
    "proof_class": {
      "type": "string",
      "enum": [
        "theorem_lookup", "normalization", "arithmetic_automation", "induction",
        "witness_construction", "case_analysis", "multi_lemma_composition"
      ]
    },
    "proof_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_proof_class"],
      "properties": {
        "primary_proof_class": { "$ref": "#/$defs/proof_class" },
        "secondary_proof_classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/proof_class" },
          "uniqueItems": true
        },
        "automation_level": { "type": "string", "enum": ["none", "assisted", "semi_automated", "fully_automated"] },
        "retrieval_depth": { "type": "integer", "minimum": 0 },
        "planning_depth": { "type": "integer", "minimum": 0 },
        "branch_count": { "type": "integer", "minimum": 0 },
        "dependency_composition_depth": { "type": "integer", "minimum": 0 },
        "uses_witness_invention": { "type": "boolean" },
        "uses_induction": { "type": "boolean" },
        "uses_contradiction": { "type": "boolean" },
        "uses_case_analysis": { "type": "boolean" }
      }
    },
    "dependency_claim_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependency_id", "category", "source"],
      "properties": {
        "dependency_id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "declared", "used", "obligation", "verified_module_item",
            "retrieval_candidate", "retrieved_unused"
          ]
        },
        "source": { "type": "string", "enum": ["manual", "proof_search_import", "verifier_export"] }
      }
    },
    "dependency_manifest": {
      "type": "object",
      "additionalProperties": false,
      "description": "Richer, Proof-Search-sourced dependency evidence. Distinct from (and additive to) the shallow top-level 'dependencies' object: this record distinguishes declared, retrieved, and actually-used dependencies rather than merging them into one list.",
      "properties": {
        "environment_hash": { "type": "string" },
        "declared_theorem_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "used_theorem_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "obligation_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "verified_module_item_deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "transitive_dependency_count": { "type": ["integer", "null"], "minimum": 0 },
        "transitive_dependency_depth": { "type": ["integer", "null"], "minimum": 0 },
        "retrieval_candidates": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "retrieved_unused_candidates": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "claim_sources": { "type": "array", "items": { "$ref": "#/$defs/dependency_claim_source" } }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "message": { "type": "string" },
        "source_span": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } },
        "local_context": { "type": "array", "items": { "type": "string" } },
        "unsolved_goals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "attempt_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt_id", "outcome"],
      "properties": {
        "attempt_id": { "type": "string", "minLength": 1 },
        "episode_id": { "type": ["string", "null"] },
        "outcome": { "type": "string", "enum": ["succeeded", "failed", "abandoned"] },
        "diagnostic_category": { "type": ["string", "null"] },
        "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" } },
        "tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cost": { "type": ["number", "null"], "minimum": 0 },
        "wall_time_ms": { "type": ["number", "null"], "minimum": 0 },
        "lean_cpu_time_ms": { "type": ["number", "null"], "minimum": 0 },
        "model_run_id": { "type": ["string", "null"] },
        "model_config_hash": { "$ref": "#/$defs/sha256_or_null" },
        "prompt_hash": { "$ref": "#/$defs/sha256_or_null" },
        "context_hash": { "$ref": "#/$defs/sha256_or_null" },
        "proof_variant_id": { "type": ["string", "null"] }
      }
    },
    "negative_example_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "negative_id", "attempt_id", "origin", "proof_authority",
        "can_export_metadata", "can_export_proof_text", "can_export_diagnostics", "can_export_model_identity"
      ],
      "properties": {
        "negative_id": { "type": "string", "minLength": 1 },
        "attempt_id": {
          "type": "string",
          "minLength": 1,
          "description": "attempt_id of the entry in this packet's own 'attempts' this negative example is derived from."
        },
        "origin": { "type": "string", "enum": ["organic", "controlled_mutation"] },
        "diagnostic_category": { "type": ["string", "null"] },
        "candidate_source_ref": {
          "type": ["string", "null"],
          "description": "Governed artifact reference the failed candidate proof text can be recovered from, if retained."
        },
        "proof_authority": { "const": "none" },
        "can_export_metadata": { "type": "boolean" },
        "can_export_proof_text": { "type": "boolean" },
        "can_export_diagnostics": { "type": "boolean" },
        "can_export_model_identity": { "type": "boolean" }
      }
    },
    "repair_trajectory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trajectory_id", "steps", "terminal_outcome", "terminal_ref"],
      "properties": {
        "trajectory_id": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_index", "from_attempt_id", "repair_action", "to_ref", "step_hash"],
            "properties": {
              "step_index": { "type": "integer", "minimum": 0 },
              "from_attempt_id": {
                "type": "string",
                "minLength": 1,
                "description": "attempt_id of the entry in this packet's own 'attempts' this step repairs."
              },
              "repair_action": { "type": "string", "minLength": 1 },
              "diagnostic_category_addressed": { "type": ["string", "null"] },
              "to_ref": {
                "type": "string",
                "minLength": 1,
                "description": "attempt_id or proof_variants[].variant_id in this same packet that this step produced."
              },
              "step_hash": {
                "$ref": "#/$defs/sha256",
                "description": "SHA-256 over canonical JSON of {step_index, from_attempt_id, repair_action, diagnostic_category_addressed, to_ref} — see tools/mathcorpus/hashing.repair_step_hash."
              }
            }
          }
        },
        "terminal_outcome": { "type": "string", "enum": ["verified_proof", "explicit_failure"] },
        "terminal_ref": {
          "type": "string",
          "minLength": 1,
          "description": "For 'verified_proof': a proof_variants[].variant_id in this packet, or (if the successful proof was filed as its own packet) another packet's packet_id. For 'explicit_failure': an attempt_id in this packet's own 'attempts'."
        }
      }
    },
    "model_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_run_id", "evaluation_suite_version", "policy_version",
        "model_family", "model_version", "model_config_hash"
      ],
      "properties": {
        "model_run_id": { "type": "string", "minLength": 1 },
        "evaluation_suite_version": { "type": "string", "minLength": 1 },
        "policy_version": { "type": "string", "minLength": 1 },
        "model_family": { "type": "string", "minLength": 1 },
        "model_version": { "type": "string", "minLength": 1 },
        "model_config_hash": { "$ref": "#/$defs/sha256" },
        "episode_count": { "type": "integer", "minimum": 0 },
        "seeds": { "type": "array", "items": { "type": "integer" } },
        "first_attempt_pass_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "eventual_pass_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "attempts_to_pass_distribution": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cost": { "type": ["number", "null"], "minimum": 0 },
        "wall_time_ms": { "type": ["number", "null"], "minimum": 0 },
        "lean_cpu_time_ms": { "type": ["number", "null"], "minimum": 0 },
        "failure_category_distribution": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "censored_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of fields on this record whose true value is known but deliberately withheld (e.g. by export/redaction policy) — distinct from null, which means 'not collected'."
        }
      }
    },
    "empirical_difficulty_aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregate_id", "model_run_ids", "calibration_version",
        "observed_difficulty_score", "calibrated_difficulty_bin",
        "evaluation_suite_version", "policy_version"
      ],
      "properties": {
        "aggregate_id": { "type": "string", "minLength": 1 },
        "model_run_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "description": "model_run_id values, from this same packet's own 'model_runs', this aggregate was reproducibly computed from."
        },
        "calibration_version": {
          "type": "string",
          "enum": ["v1"],
          "description": "Which formula in tools/mathcorpus/difficulty.py computed this aggregate. A new formula gets a new version rather than silently changing what a stored score means."
        },
        "observed_difficulty_score": { "type": "number" },
        "calibrated_difficulty_bin": { "$ref": "#/$defs/difficulty_bin_value" },
        "author_difficulty_bin": {
          "oneOf": [
            { "$ref": "#/$defs/difficulty_bin_value" },
            { "type": "null" }
          ],
          "description": "Echo of the packet's own top-level difficulty_bin at aggregation time, for comparison only. Never used to overwrite it."
        },
        "evaluation_suite_version": { "type": "string", "minLength": 1 },
        "policy_version": { "type": "string", "minLength": 1 },
        "computed_at": { "$ref": "#/$defs/iso_timestamp_or_null" }
      }
    },
    "difficulty_bin_value": { "type": "string", "enum": ["D0", "D1", "D2", "D3", "D4", "D5"] },
    "iso_timestamp_or_null": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "idea_attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attribution_id", "literature_source_id", "source_sha256_pin",
        "attribution_status", "visibility"
      ],
      "properties": {
        "attribution_id": { "type": "string", "minLength": 1 },
        "formal_statement_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_variant_id": { "type": ["string", "null"] },
        "literature_source_id": { "type": "string", "minLength": 1 },
        "external_claim_id": { "type": ["string", "null"] },
        "source_sha256_pin": {
          "$ref": "#/$defs/sha256",
          "description": "Hash-pin of the referenced literature_sources/ catalog entry's record_hash at attribution time."
        },
        "attribution_status": {
          "type": "string",
          "enum": [
            "directly_used", "likely_influential", "background_only",
            "independent_rediscovery", "uncertain", "not_used"
          ]
        },
        "visibility": { "type": "string", "enum": ["model_visible", "post_hoc"] },
        "dependency_refs": { "type": "array", "items": { "type": "string" } },
        "reviewer": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      }
    },
    "prior_art_match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_id", "literature_source_id", "match_type"],
      "properties": {
        "match_id": { "type": "string", "minLength": 1 },
        "formal_statement_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "literature_source_id": { "type": "string", "minLength": 1 },
        "external_claim_id": { "type": ["string", "null"] },
        "match_type": {
          "type": "string",
          "enum": ["same_result", "stronger_result", "weaker_result", "related_technique", "independent_rediscovery"]
        },
        "discovered_at": { "type": ["string", "null"] },
        "discovery_method": { "type": ["string", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "notes": { "type": ["string", "null"] }
      }
    },
    "citation_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "reviewer", "reviewer_confidence", "review_status", "reviewed_at"],
      "properties": {
        "review_id": { "type": "string", "minLength": 1 },
        "reviewed_attribution_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "reviewed_prior_art_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewer_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "review_status": { "type": "string", "enum": ["endorsed", "disputed", "needs_more_evidence"] },
        "notes": { "type": ["string", "null"] },
        "reviewed_at": { "type": "string" },
        "supersedes": { "type": ["string", "null"] }
      }
    },
    "contribution_statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement_id", "contribution_class", "author", "created_at"],
      "properties": {
        "statement_id": { "type": "string", "minLength": 1 },
        "contribution_class": {
          "type": "string",
          "enum": [
            "new_proof", "independent_rediscovery", "formalization", "verification",
            "reconstruction", "adaptation", "literature_derived_synthesis"
          ]
        },
        "known_prior_art_refs": { "type": "array", "items": { "type": "string" } },
        "literature_search_scope": { "type": ["string", "null"] },
        "literature_search_date": { "type": ["string", "null"] },
        "citation_review_ids": { "type": "array", "items": { "type": "string" } },
        "ai_assistance_disclosure": { "type": ["string", "null"] },
        "author": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string" }
      }
    },
    "proof_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id", "variant_style", "proof_body_redacted", "source"],
      "properties": {
        "variant_id": { "type": "string", "minLength": 1 },
        "variant_style": {
          "type": "string",
          "enum": ["canonical", "shortest", "pedagogical", "restricted", "interactive", "alternate_model"]
        },
        "formal_statement_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "environment_hash": { "type": "string" },
        "proof_body_path": { "type": "string" },
        "proof_body_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_body_redacted": { "type": "boolean" },
        "tactic_count": { "type": ["integer", "null"], "minimum": 0 },
        "proof_length": { "type": ["integer", "null"], "minimum": 0 },
        "restriction_profile_id": { "type": ["string", "null"] },
        "restriction_profile_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_profile": { "$ref": "#/$defs/proof_profile" },
        "model_run_id": { "type": ["string", "null"] },
        "source": { "type": "string", "enum": ["human_authored", "proof_search", "imported"] }
      },
      "allOf": [
        {
          "if": { "properties": { "variant_style": { "const": "restricted" } } },
          "then": { "required": ["restriction_profile_id", "restriction_profile_sha256"] }
        }
      ]
    }
  },
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._][a-z0-9]+)*\\.v[0-9]+$",
      "description": "Stable corpus identifier, e.g. elementary.algebra.diff_of_squares.v1"
    },
    "packet_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version for packet metadata and artifacts."
    },
    "title": { "type": "string", "minLength": 1 },
    "domain": {
      "type": "string",
      "enum": [
        "arithmetic", "algebra", "number_theory", "combinatorics",
        "analysis", "real_analysis", "geometry", "topology", "logic",
        "linear_algebra", "abstract_algebra", "set_theory", "probability",
        "frontier"
      ]
    },
    "level": {
      "type": "string",
      "enum": [
        "L0_elementary", "L1_proof_basics", "L2_olympiad", "L3_undergrad",
        "L4_advanced_undergrad", "L5_grad", "L6_known_theorem", "L7_frontier"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "concept", "theorem", "exercise", "certificate_claim",
        "negative_example", "benchmark_item", "frontier_artifact"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "kernel_verified", "verified_certificate", "formula_fact_only",
        "empirical_only", "failed_attempt", "redacted_public_metadata_only"
      ]
    },
    "difficulty_bin": {
      "type": "string",
      "enum": ["D0", "D1", "D2", "D3", "D4", "D5"],
      "description": "Packet-native difficulty bin used by the evaluation suite."
    },
    "lean_module": { "type": "string", "description": "Lean module path (required for formal items)." },
    "theorem_name": { "type": "string", "description": "Lean theorem/def name (required for formal items)." },
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit import list (required for formal items)."
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lean_version": { "type": "string" },
        "mathlib_rev": { "type": "string" },
        "std_rev": { "type": "string" },
        "lake_manifest_sha256": { "$ref": "#/$defs/sha256_or_null" }
      },
      "required": ["lean_version", "mathlib_rev"]
    },
    "source_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "authors", "statement_fidelity"],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "author_written", "adapted_public_source", "formal_conjectures",
            "erdos_problems", "proofnet_style", "repo_original",
            "imported_open_repo", "benchmark_statement", "private_audit"
          ]
        },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "authors": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "copyright_holder": { "type": "string" },
        "license_spdx": { "type": "string", "description": "SPDX id for code-like assets, e.g. Apache-2.0" },
        "license_content": { "type": "string", "description": "License for prose-like assets, e.g. CC-BY-4.0" },
        "statement_fidelity": {
          "type": "string",
          "enum": [
            "author_written", "canonical_statement_hash_match",
            "problem_fidelity_verified", "adapted_with_review", "unknown"
          ]
        },
        "provenance_attested_by": { "type": "string" },
        "provenance_checked_at": { "type": "string" }
      }
    },
    "informal_statement": { "type": "string" },
    "informal_proof_idea": { "type": "string" },
    "formal_statement_pp": { "type": "string", "description": "Pretty-printed formal statement, toolchain-pinned (required for formal items)." },
    "proof_body_path": { "type": "string", "description": "Path to Lean proof file, if public." },
    "proof_body_redacted": { "type": "boolean" },
    "certificate": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "certificate_type": { "type": "string", "enum": ["lrat", "drat", "sat_model", "cnf_witness", "none"] },
        "certificate_checker": { "type": "string", "enum": ["bv_decide_lrat", "lrat_import", "model_eval", "none"] },
        "certificate_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "certificate_artifact_redacted": { "type": "boolean" },
        "canonical_cnf_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "dimacs_serializer_version": { "type": "string" },
        "solver_name": { "type": "string" },
        "solver_version": { "type": "string" },
        "checked_at": { "type": "string" },
        "checked_by_module": { "type": "string" },
        "replay_runtime_ms": { "type": "number", "minimum": 0 },
        "memory_class": { "type": "string", "enum": ["small", "medium", "large"] },
        "private_artifact_uri": { "type": "string" }
      }
    },
    "encoding_soundness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "encoding_required": { "type": "boolean" },
        "encoding_soundness_status": { "type": "string", "enum": ["not_applicable", "stated_directly", "proved", "missing"] },
        "encoding_soundness_lemma": { "type": ["string", "null"] },
        "formula_fact_status": { "type": "string", "enum": ["proved", "not_applicable", "failed"] },
        "math_fact_status": { "type": "string", "enum": ["proved", "formula_fact_only", "empirical_only"] }
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rung", "proof_authority"],
      "properties": {
        "rung": { "type": "integer", "minimum": 0, "maximum": 5 },
        "proof_authority": { "type": "string", "enum": ["lean_kernel", "lean_verified_lrat", "kernel_rechecked_witness", "none"] },
        "certificate_checker": { "type": "string", "enum": ["kernel_decide", "bv_decide_lrat", "model_eval", "lrat_import", "none"] },
        "formula_fact_status": { "type": "string", "enum": ["proved", "not_applicable", "failed"] },
        "math_fact_status": { "type": "string", "enum": ["proved", "formula_fact_only", "empirical_only"] },
        "encoding_required": { "type": "boolean" },
        "encoding_soundness_status": { "type": "string", "enum": ["not_applicable", "stated_directly", "proved", "missing"] },
        "independent_review_status": { "type": "string", "enum": ["none", "self_reviewed", "repo_reviewed", "external_reviewed"] },
        "public_claim_class": { "type": "string", "enum": ["public_safe", "restricted", "private_only"] }
      }
    },
    "training": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligibility"],
      "properties": {
        "eligibility": {
          "type": "string",
          "enum": [
            "public_train", "public_val", "public_test", "heldout_public",
            "heldout_private", "quarantined", "quarantined_benchmark",
            "negative_example_only", "private_audit_only", "disallowed"
          ]
        },
        "split": { "type": "string", "enum": ["train", "val", "test_public", "heldout_public", "heldout_private", "quarantined", "private_audit_only"] },
        "reason_codes": { "type": "array", "items": { "type": "string" } },
        "dedupe_cluster_id": { "type": "string" },
        "template_family_id": { "type": "string" },
        "benchmark_tags": { "type": "array", "items": { "type": "string" } },
        "open_problem_related": { "type": "boolean" },
        "contamination_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "can_export_proof_body": { "type": "boolean" },
        "can_export_certificate_metadata": { "type": "boolean" },
        "can_export_certificate_file": { "type": "boolean" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured record for negative_example / failed_attempt packets.",
      "properties": {
        "gap_category": { "type": "string" },
        "sub_category": { "type": "string" },
        "input_context_summary": { "type": "string" },
        "attempt_summary": { "type": "string" },
        "lesson": { "type": "string" }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theorem_deps": { "type": "array", "items": { "type": "string" } },
        "kits": { "type": "array", "items": { "type": "string" } },
        "tactic_tags": { "type": "array", "items": { "type": "string" } },
        "prerequisite_concepts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "proof_variants": {
      "type": "array",
      "description": "Zero or more additional proofs of this packet's statement, in styles other than (or including) the canonical proof_body_path. Adding variants never mutates the packet's own canonical identity/hash fields. See schema/mcip/v1/README.md — these mirror the MCIP ProofVariant/ProofProfile shapes. Cross-field checks (statement/environment/proof hash must match parent evidence; restricted variants must hash-pin a resolvable restriction profile) are enforced by tools/validate_packets.py.",
      "items": { "$ref": "#/$defs/proof_variant" }
    },
    "dependency_manifest": { "$ref": "#/$defs/dependency_manifest" },
    "attempts": {
      "type": "array",
      "description": "This packet's own recorded proof-search attempts, successful and failed, that led to its current state. See schema/mcip/v1/README.md — mirrors MCIP's AttemptRecord.",
      "items": { "$ref": "#/$defs/attempt_record" }
    },
    "negative_examples": {
      "type": "array",
      "description": "Failed attempts (from 'attempts') preserved as labeled, non-proof-bearing evidence. proof_authority is fixed to 'none' at the schema level.",
      "items": { "$ref": "#/$defs/negative_example_record" }
    },
    "repair_trajectories": {
      "type": "array",
      "description": "Ordered, hash-linked chains from a failed attempt to a terminus (a verified proof variant or an explicit final failure).",
      "items": { "$ref": "#/$defs/repair_trajectory" }
    },
    "model_runs": {
      "type": "array",
      "description": "Multi-model empirical evaluation evidence for this packet. Additive; never overwrites author-assigned difficulty_bin. See schema/mcip/v1/README.md — mirrors MCIP's ModelRun.",
      "items": { "$ref": "#/$defs/model_run" }
    },
    "empirical_difficulty_aggregates": {
      "type": "array",
      "description": "Difficulty observed empirically across one or more of this packet's own 'model_runs', kept strictly separate from the top-level author-assigned difficulty_bin. Multiple aggregates (different suites, or historical re-runs) may coexist.",
      "items": { "$ref": "#/$defs/empirical_difficulty_aggregate" }
    },
    "idea_attributions": {
      "type": "array",
      "description": "Claims that a literature_sources/ catalog entry influenced (or explicitly did not influence) this packet's proof. Never changes kernel-verification status — this is child evidence about provenance, not proof authority. See schema/ENUMS.md#literature-lineage.",
      "items": { "$ref": "#/$defs/idea_attribution" }
    },
    "prior_art_matches": {
      "type": "array",
      "description": "Post-hoc findings that existing published work overlaps with this packet's result. Inherently post-hoc by record type — never conflated with idea_attributions[].visibility='model_visible' evidence.",
      "items": { "$ref": "#/$defs/prior_art_match" }
    },
    "citation_reviews": {
      "type": "array",
      "description": "Reviewer assessments of this packet's idea_attributions/prior_art_matches. Multiple, even disputed, reviews coexist as separate entries; a new review never overwrites an earlier one.",
      "items": { "$ref": "#/$defs/citation_review" }
    },
    "contribution_statements": {
      "type": "array",
      "description": "Declarations of what kind of new contribution this packet's proof represents. Kernel verification alone never implies a contribution_class. Multiple statements may exist over time; earlier ones are not deleted when revised.",
      "items": { "$ref": "#/$defs/contribution_statement" }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "loc": { "type": "integer", "minimum": 0 },
        "tactic_count": { "type": "integer", "minimum": 0 },
        "runtime_ms": { "type": "number", "minimum": 0 },
        "heartbeats": { "type": "integer", "minimum": 0 },
        "proof_length": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "public_files": { "type": "array", "items": { "type": "string" } },
        "private_artifact_inventory": { "type": "array", "items": { "type": "string" } }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_basis": { "type": "string" },
        "reviewer_status": { "type": "string", "enum": ["none", "self_reviewed", "repo_reviewed", "external_reviewed"] },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "description": "Provenance of the tracked verifier run that produced this packet's proof authority. Present on kernel_verified / verified_certificate packets produced through the proof-search loop.",
      "properties": {
        "verifier": { "type": "string", "description": "e.g. 'proofsearch'" },
        "environment_hash": { "type": "string", "description": "Pinned Lean+mathlib environment hash the kernel ran under." },
        "episode_id": { "type": "string" },
        "outcome": { "type": "string", "enum": ["kernel_verified", "certified", "verified_certificate"] },
        "kernel_verified": { "type": "boolean" },
        "fidelity_status": { "type": "string", "enum": ["attested", "verified", "unreviewed"] },
        "import_manifest_hash": { "type": "string" },
        "trajectory_first_hash": { "type": "string" },
        "trajectory_last_hash": { "type": "string" },
        "step_count": { "type": "integer", "minimum": 0 },
        "verified_at": { "type": "string" }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_sha256"],
      "properties": {
        "source_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "formal_statement_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "proof_body_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "module_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "canonical_cnf_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "certificate_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "private_artifact_bundle_sha256": { "$ref": "#/$defs/sha256_or_null" },
        "packet_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "notes": { "type": "string" }
  }
}
